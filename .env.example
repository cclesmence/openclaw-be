# OpenClaw CLI binary name or absolute path
OPENCLAW_BINARY=openclaw

# Agent + session key mapping tới skill /apply đã có trong openclaw-config
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION_KEY=agent:main:auto-apply

# Timeout cho lệnh openclaw agent (milliseconds)
OPENCLAW_TIMEOUT_MS=600000

# NestJS server port
PORT=3000

# Tuỳ chọn: webhook nhận kết quả auto-apply (tool-jobs)
TOOL_JOBS_WEBHOOK_URL=
TOOL_JOBS_WEBHOOK_TOKEN=
